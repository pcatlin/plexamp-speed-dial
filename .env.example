# Copy to .env and set every value. Docker Compose substitutes these into the compose file.
# Plex server URL, TLS, Sonos discovery, and line-in are configured only in the app Setup UI (stored in the DB).

# --- Postgres (db service + API DATABASE_URL must match host db, user, password, database) ---
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# --- Frontend dev: API base URL (not stored in Setup) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Optional: Plex HTTP client identity (not in Setup UI; stable value avoids “new device” on rebuilds) ---
# PLEX_CLIENT_IDENTIFIER=
# PLEX_DEVICE_NAME=
# PLEX_PRODUCT=

# --- Optional: CORS for the API (not in Setup UI) ---
# CORS_ORIGINS=*
