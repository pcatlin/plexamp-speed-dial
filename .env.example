POSTGRES_DB=plexamp_speed_dial
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/plexamp_speed_dial
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Plex Media Server base URL — must be reachable from the API process:
# Docker on Mac/Windows: host.docker.internal:32400; Linux Docker: LAN IP of the Plex host.
# Local uvicorn: http://127.0.0.1:32400 if Plex is on the same machine.
PLEX_SERVER_URL=http://host.docker.internal:32400
# HTTPS with self-signed cert from within Docker (not recommended unless required):
# PLEX_SSL_VERIFY=false

# Sonos: SSDP/multicast from the API container usually cannot see your LAN players.
# Set the LAN IP of any one Sonos device; the API will enumerate the whole household over TCP.
# SONOS_SEED_IPS=192.168.1.50
# SONOS_DISCOVER_TIMEOUT=10
# SONOS_ALLOW_NETWORK_SCAN=true
# SONOS_INTERFACE_ADDR=
# SONOS_DEMO_FALLBACK=false
