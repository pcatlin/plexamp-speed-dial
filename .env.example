# Copy to .env and set every value. Docker Compose substitutes these into the compose file.
# Plex client id is generated on first API start and stored in the database (runtime_setup).

# --- Postgres (db service + API DATABASE_URL must match host db, user, password, database) ---
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# --- Frontend dev: API base URL ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Optional: CORS for the API ---
# CORS_ORIGINS=*
