# Optional: used for local frontend dev (Vite) and optional API env overrides.
# Docker Compose uses fixed Postgres + DATABASE_URL in docker-compose.yml (no DB vars needed here).

# --- Frontend dev: API base URL ---
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Optional: CORS for the API (local uvicorn / overrides) ---
# CORS_ORIGINS=*
